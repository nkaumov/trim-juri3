NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_PLATFORM_TENANT_ID=local-tenant
NEXT_PUBLIC_PLATFORM_AGENT_ID=jurist3-agent



# Runtime-only vars (рекомендуется для серверов, где URL может меняться, напр. trycloudflare).
# Эти переменные читаются в рантайме без пересборки образа.
PLATFORM_TENANT_ID=
PLATFORM_AGENT_ID=


# Platform integration (remote Platform: Hub/API)
PLATFORM_API_URL=https://api.platform.foxyway.chat
PLATFORM_HUB_URL=wss://hub.platform.foxyway.chat/ws
PLATFORM_API_KEY=
# Must be allowed in the API key settings (allowed origins). For dev you can set "*" in Platform.
PLATFORM_ORIGIN=http://localhost:3001
# Platform processing timeout (ms). Default: 180000 (3 minutes)
PLATFORM_TIMEOUT_MS=180000


AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Legacy fallback vars (optional)
PLATFORM_OPENAI_API_KEY=
PLATFORM_OPENAI_MODEL=
# Database
POSTGRES_USER=jurist3
POSTGRES_PASSWORD=jurist3
POSTGRES_DB=jurist3
DATABASE_URL=postgres://jurist3:jurist3@jurist3-db:5432/jurist3

# Document storage encryption (32 bytes base64). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DOCUMENTS_ENCRYPTION_KEY=

# Bootstrap admin (first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Dev: clear all sessions on server start
CLEAR_SESSIONS_ON_START=true
