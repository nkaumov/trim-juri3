NEXT_PUBLIC_API_BASE_URL=http://host.docker.internal:8000
NEXT_PUBLIC_PLATFORM_TENANT_ID=local-tenant
NEXT_PUBLIC_PLATFORM_AGENT_ID=jurist3-agent
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8085
NEXT_PUBLIC_ONLYOFFICE_FILE_BASE_URL=http://host.docker.internal:3002


AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Legacy fallback vars (optional)
PLATFORM_OPENAI_API_KEY=
PLATFORM_OPENAI_MODEL=
# Database
POSTGRES_USER=jurist3
POSTGRES_PASSWORD=jurist3
POSTGRES_DB=jurist3
DATABASE_URL=postgres://jurist3:jurist3@localhost:5434/jurist3

# Document storage encryption (32 bytes base64). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DOCUMENTS_ENCRYPTION_KEY=
DOCUMENTS_SIGNING_KEY=

# Bootstrap admin (first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Dev: clear all sessions on server start
CLEAR_SESSIONS_ON_START=true

# Integration mode (widget/API access without login form)
JURI3_INTEGRATION_API_TOKEN=change-me-integration-token
JURI3_INTEGRATION_USER_EMAIL=integration@jurist3.local
JURI3_INTEGRATION_DEFAULT_ORIGIN=http://localhost:3030
JURI3_INTEGRATION_SESSION_SECRET=change-me-integration-session-secret
JURI3_PLATFORM_API_BASE_URL=http://api:8000
JURI3_INTEGRATION_SKIP_PLATFORM_VERIFY=false
